{
  "$schema": "https://opencode.ai/config.json",
  "lsp": true,
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
    // "oh-my-openagent@latest"
  ],
  "mcp": {
    // "zotero": { "type": "local", "command": [ "zotero-mcp", "serve" ], "enabled": true }
  },
  "permission": {
    "external_directory": {
      "~/.config/opencode/**": "allow"
    },
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "compress": "allow",
    "question": "allow",
    "write": "ask",
    "edit": "ask",
    "task": "ask",
    "bash": {
      "*": "ask",
      "ls*": "allow",
      "pwd": "allow",
      "which*": "allow",
      "realpath*": "allow",
      "file*": "allow",
      "stat*": "allow",
      "uname*": "allow",
      "hostname": "allow",
      "whoami": "allow",
      "date": "allow",
      "cat*": "allow",
      "head*": "allow",
      "tail*": "allow",
      "wc*": "allow",
      "echo*": "allow",
      "type*": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git blame*": "allow",
      "git branch*": "allow",
      "git ls-files*": "allow",
      "git stash list*": "allow",
      "git remote*": "allow",
      "git rev-parse*": "allow",
      "git describe*": "allow",
      "git shortlog*": "allow",
      "git stash show*": "allow",
      "git reflog*": "allow",
      "git fetch*": "allow",
      "git grep*": "allow",
      "rg*": "allow",
      "grep*": "allow",
      "find*": "allow",
      "tree*": "allow",
      "du*": "allow",
      "df*": "allow",
      "env": "allow",
      "printenv*": "allow",
      "history": "allow",
      "curl*": "ask",
      "wget*": "ask",
      "npm view*": "allow",
      "npm info*": "allow",
      "npm show*": "allow",
      "npm search*": "allow",
      "pip show*": "allow",
      "pip index*": "allow",
      "cargo search*": "allow",
      "cargo info*": "allow",
      "prettier*": "allow",
      "bun run*": "ask",
      "npm run*": "ask",
      "pnpm run*": "ask",
      "yarn run*": "ask",
      "npx *": "ask",
      "tsc*": "ask",
      "bunx*": "ask",
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "git pull*": "ask",
      "git merge*": "ask",
      "git checkout*": "ask",
      "git switch*": "ask",
      "git restore*": "ask",
      "git reset*": "ask",
      "git rebase*": "ask",
      "git stash push*": "ask",
      "git stash pop*": "ask",
      "git stash drop*": "ask",
      "git tag*": "ask",
      "git rm*": "ask",
      "git clean*": "ask",
      "git worktree*": "ask",
      "git config*": "ask",
      "rm -rf *": "ask",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "sudo*": "deny",
      "chmod*": "ask",
      "chown*": "ask",
      "> /dev/*": "deny",
      "mkfs*": "deny",
      "dd*": "deny",
      "fdisk*": "deny",
      "parted*": "deny",
      "mount*": "deny",
      "reboot": "deny",
      "shutdown": "deny",
      "poweroff": "deny",
      "passwd*": "deny",
      "useradd*": "deny",
      "usermod*": "deny",
      "userdel*": "deny",
      "groupadd*": "deny",
      "groupmod*": "deny",
      "groupdel*": "deny",
      "kill*": "ask",
      "pkill*": "ask",
      "docker*": "ask",
      "podman*": "ask",
      "kubectl*": "ask",
      "helm*": "ask",
      "systemctl*": "ask",
      "journalctl*": "allow"
    }
  }
}
