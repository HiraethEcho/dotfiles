{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/Code",
        "~/obsidian"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "zotero": {
      "command": "mcp-zotero",
      "env": {
        "ZOTERO_API_KEY": "vxwGh0XaMLa637qhhGYZ48LS",
        "ZOTERO_USER_ID": "9666949"
      }
    },
    "obsidian": {
      "command": "npx",
      "args": ["-y", "obsidian-mcp", "/home/hiraeth/obsidian"]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "Cloudflare Playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@smithery/cli@latest",
        "run",
        "@cloudflare/playwright-mcp",
        "--key",
        "fe6b84f1-bf59-4f0a-aac3-5c69908a423e",
        "--profile",
        "sole-mole-Ejp5VC"
      ]
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "~/obsidian"]
    },
    "playwright": {
      "command": "npx",
      "args": ["@executeautomation/playwright-mcp-server"]
    },
    "bilibili-search": {
      "command": "npx",
      "args": ["bilibili-mcp"],
      "description": "B站视频搜索 MCP 服务，可以在AI应用中搜索B站视频内容。"
    },
    "markmap": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@jinzcdev/markmap-mcp-server"],
      "env": {
        "MARKMAP_DIR": "~/Code/markup"
      }
    }
  }
}
