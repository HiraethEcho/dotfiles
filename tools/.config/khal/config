[calendars]

[[local_ical]]
path = ~/.local/share/calendars/*
type = discover

[[local_test]]
path = ~/.local/share/calendarstest/*
type = discover

[locale]
timeformat = %H:%M
dateformat = %Y-%m-%d
longdateformat = %Y-%m-%d
datetimeformat = %Y-%m-%d %H:%M
longdatetimeformat = %Y-%m-%d %H:%M

[default]
default_calendar =
