#!/bin/bash
# daily sync, pull or push

set -euo pipefail

CONFLICT_DIR="$HOME/conflicts"
GIT_REPO=(
  "$HOME/Documents/math"
  "$HOME/Code/docs"
  "$HOME/memex"
  "$HOME/Sites/content/"
  "$HOME/.config/nvim"
  "$HOME/dotfiles"
)

RCLONE_PAIR=(
  "$HOME/obsidian/;koofr:/obsidian/"
  "$HOME/Documents/zotero_files/;koofr:/kDocuments/zotero_files/"
  "$HOME/Documents/zotero_files/;tera:/Documents/zotero_files/"
  "$HOME/Documents/sorge/;koofr:/kDocuments/sorge/"
  "$HOME/Documents/sorge/;tera:/Documents/sorge/"
  "$HOME/Documents/projects/;koofr:/kDocuments/projects/"
  "$HOME/Documents/projects/;tera:/Documents/projects/"
  "$HOME/.local/share/calendar_radicale/;koofr:/asset/radicale-hiraeth-collection/"
  "$HOME/Documents/math/;koofr:/kDocuments/math/"
  "$HOME/Documents/math/;tera:/Documents/math/"
  "$HOME/Code/docs/;koofr:/docs/"
  "$HOME/Code/docs/;tera:/docs/"
  "$HOME/memex/;koofr:/memex/"
)

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

TOTAL_LOG=""
POWER=""
INTERACTIVE=""
DRY_RUN=""
RCLONE_INTERACTIVE=""
AUTO_STASH="yes"

log() {
  echo -e "$1"
  TOTAL_LOG+="$1\n"
}

log_ok() {
  log "${GREEN}$1${NC}"
}

log_err() {
  log "${RED}$1${NC}"
}

log_info() {
  log "${YELLOW}$1${NC}"
}

fail() {
  log_err "$1"
  notify-send -u critical "dcna" "$1"
}

ok() {
  log_ok "$1"
}

dry_info() {
  log "${YELLOW}[DRY RUN] $1${NC}"
}

dry_run() {
  [ -n "$DRY_RUN" ]
}

total_log() {
  echo "----"
  log_info "LOG:"
  echo -e "$TOTAL_LOG"
}

show_help() {
  echo -e "${GREEN}dcna — 日常同步/备份工具${NC}"
  echo ""
  echo -e "${GREEN}用法:${NC}"
  echo "  dcna <命令> [选项]"
  echo "  选项可放在命令前或后: dcna -i day, dcna day -i"
  echo ""
  echo -e "${GREEN}命令:${NC}"
  echo "  d, day, c, coffee    白天: rclone拉取 + git拉取"
  echo "  n, night, a, alcohol 夜间: 日历同步 + rclone推送 + git推送 + 系统更新 + 备份 + 关机提示"
  echo "  rp                   rclone拉取全部"
  echo "  rP                   rclone推送全部 (24h内有修改的文件)"
  echo "  rPf                  rclone强制推送全部 (无视时间限制)"
  echo "  gp                   git拉取全部"
  echo "  gP                   git推送全部"
  echo "  re                   shutdown/reboot/lock/sleep 操作"
  echo "  bak                  系统更新 + timeshift + grub + 包列表备份 (需sudo)"
  echo "  config               显示当前配置"
  echo "  help                 显示此帮助"
  echo ""
  echo -e "${GREEN}选项:${NC}"
  echo "  -i          交互模式 (paru不自动确认, rclone显示交互确认)"
  echo "  -u <操作>   跳过关机提示, 直接执行指定操作: r=重启 u=关机 l=锁屏 s=休眠 n=取消"
  echo "  -n          dry-run, 仅显示将执行的操作, 不实际执行"
  echo "  -h, --help  显示此帮助"
  echo ""
  echo -e "${YELLOW}注意: 所有路径已在脚本内配置，无需手动输入。${NC}"
  echo -e "${YELLOW}      AUTO_STASH=${AUTO_STASH}${NC}"
  echo -e "${YELLOW}      默认自动stash未提交的更改再拉取。${NC}"
}

show_config() {
  log_info "当前配置:"
  echo ""
  echo -e "${GREEN}Git 仓库:${NC}"
  for repo in "${GIT_REPO[@]}"; do
    echo "  - $repo"
  done
  echo ""
  echo -e "${GREEN}Rclone 同步任务:${NC}"
  for pair in "${RCLONE_PAIR[@]}"; do
    echo "  - $pair"
  done
  echo ""
  echo -e "${GREEN}其他选项:${NC}"
  echo "  - AUTO_STASH: $AUTO_STASH"
  echo "  - DRY_RUN: ${DRY_RUN:-no}"
}

check_sudo() {
  if ! sudo -v &>/dev/null; then
    log_err "错误: 需要sudo权限"
    return 1
  fi
}

git_pull_all() {
  log_info "Git Pull All"
  for i in "${GIT_REPO[@]}"; do
    pushd "$i" >/dev/null || { fail "无法进入 $i"; continue; }
    log_info "处理 Git 仓库: $i"
    if [[ -n "$(git status --porcelain)" ]]; then
      if dry_run; then
        dry_info "git stash → $i"
      else
        log "Try stash"
        if git stash; then
          fail "STASHED $i"
        else
          fail "stash failed $i"
        fi
      fi
    fi
    if dry_run; then
      dry_info "git pull → $i"
    else
      if git pull; then
        ok "拉取成功 $i"
      else
        fail "拉取失败 $i"
      fi
    fi
    popd >/dev/null
  done
}

git_push_all() {
  log_info "Git Push All"
  for i in "${GIT_REPO[@]}"; do
    pushd "$i" >/dev/null || { fail "无法进入 $i"; continue; }
    log_info "正在处理 Git 仓库: $i"
    if dry_run; then
      if [[ -n "$(git status --porcelain)" ]]; then
        dry_info "git add + commit + push → $i"
      else
        ok "No Change $i"
      fi
    else
      if [[ -n "$(git status --porcelain)" ]]; then
        git add .
        git commit -m "backup at $(date +%y/%m/%d-%T)"
        if git push; then
          ok "推送成功 $i"
        else
          fail "推送失败 $i"
        fi
      else
        ok "No Change $i"
      fi
    fi
    popd >/dev/null
  done
}

system_bak() {
  if dry_run; then
    dry_info "paru -Syu"
    dry_info "sudo timeshift --check"
    dry_info "sudo grub-mkconfig -o /boot/grub/grub.cfg"
    dry_info "pacman -Qqe > Qqe.bak && pacman -Qe > Qe.bak"
    return
  fi

  local PARU_INTERACTIVE=""
  if [ -z "$INTERACTIVE" ]; then
    PARU_INTERACTIVE="--noconfirm"
  fi

  log_info "运行系统更新..."
  if paru -Syu "$PARU_INTERACTIVE"; then
    ok "更新成功"
  else
    log_err "更新失败"
  fi

  log_info "创建系统备份..."
  if sudo timeshift --check; then
    ok "备份成功"
  else
    log_err "备份失败"
  fi

  log_info "更新GRUB配置..."
  if sudo grub-mkconfig -o /boot/grub/grub.cfg; then
    ok "GRUB更新成功"
  else
    log_err "GRUB更新失败"
  fi

  log_info "备份package list..."
  if pacman -Qqe >"$HOME/Desktop/bak/Qqe-$(whoami).bak" &&
     pacman -Qe >"$HOME/Desktop/bak/Qe-$(whoami).bak"; then
    ok "备份成功"
  else
    log_err "备份失败"
  fi
}

RCLONE_BASE_FLAGS="-P -v --track-renames --filter-from $HOME/.config/rclone/filter-list.txt --no-update-dir-modtime --no-update-modtime --transfers 20 -L"
RCLONE_PUSH_FLAGS="$RCLONE_BASE_FLAGS --suffix-keep-extension --max-age 24h"
RCLONE_PUSH_FORCE_FLAGS="$RCLONE_BASE_FLAGS --suffix-keep-extension"
RCLONE_PULL_FLAGS="$RCLONE_BASE_FLAGS"
RCLONE_DRY=""

rclone_pull_all() {
  log_info "Rclone Pull All"
  for pair in "${RCLONE_PAIR[@]}"; do
    IFS=";" read -r local remote <<<"$pair"
    log_info "拉取: $remote → $local"
    if rclone sync "$remote" "$local" $RCLONE_INTERACTIVE $RCLONE_DRY $RCLONE_PULL_FLAGS; then
      ok "拉取完成: $remote → $local"
    else
      fail "拉取失败: $remote → $local"
    fi
    if [ -d "$CONFLICT_DIR" ]; then
      fail "Rclone has conflicts in $CONFLICT_DIR"
    fi
  done
}

rclone_push_all() {
  local extra_flags=${1:-$RCLONE_PUSH_FLAGS}
  log_info "Rclone Push All"
  for pair in "${RCLONE_PAIR[@]}"; do
    IFS=";" read -r local remote <<<"$pair"
    log_info "推送: $local → $remote"
    if rclone sync "$local" "$remote" $RCLONE_INTERACTIVE $RCLONE_DRY $extra_flags; then
      ok "推送完成: $local → $remote"
    else
      fail "推送失败: $local → $remote"
    fi
  done
}

rclone_push_all_force() {
  rclone_push_all "$RCLONE_PUSH_FORCE_FLAGS"
}

night_reboot() {
  if dry_run; then
    dry_info "night_reboot: systemctl (reboot/poweroff) or lock screen"
    return
  fi
  if [ -z "$POWER" ]; then
    echo -e "${YELLOW}[r]eboot/sh[u]tdown/[l]ock/[s]leep/[n]othing ?${NC}"
    read -r -t 5 -s -n 1 POWER
  fi
  case "$POWER" in
  r) systemctl reboot ;;
  u) systemctl poweroff -i ;;
  l)
    slock &
    sleep .5
    xset dpms force off
    ;;
  s)
    sleep .5
    xset dpms force off
    ;;
  n | *)
    echo -e "操作已取消"
    ;;
  esac
}

day() {
  rclone_pull_all "$@"
  git_pull_all "$@"
  total_log "$@"
  if [ -d "$CONFLICT_DIR" ]; then
    cd "$CONFLICT_DIR" || return
  fi
}

night() {
  misc
  rclone_push_all "$@"
  git_push_all "$@"
  system_bak "$@"
  total_log "$@"
  night_reboot "$@"
}

misc() {
  if dry_run; then
    dry_info "vdirsyncer sync radicale"
    return
  fi
  vdirsyncer sync radicale
}

main() {
  local positional=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --help) show_help; exit 0 ;;
    --) shift; positional+=("$@"); break ;;
    -h) show_help; exit 0 ;;
    -i) INTERACTIVE="yes"; RCLONE_INTERACTIVE="-i"; shift ;;
    -n) DRY_RUN="yes"; shift ;;
    -u) POWER="$2"; shift 2 ;;
    -[A-Za-z]*)
      local chars="${1#-}"
      shift
      while [[ -n "$chars" ]]; do
        local f="${chars:0:1}"
        chars="${chars:1}"
        case "$f" in
        i) INTERACTIVE="yes"; RCLONE_INTERACTIVE="-i" ;;
        n) DRY_RUN="yes" ;;
        h) show_help; exit 0 ;;
        u)
          if [[ -n "$chars" ]]; then
            POWER="$chars"; chars=""
          elif [[ $# -gt 0 ]]; then
            POWER="$1"; shift
          else
            echo "error: -u needs a value" >&2; exit 1
          fi
          ;;
        *) echo "invalid option: -$f" >&2; exit 1 ;;
        esac
      done
      ;;
    *) positional+=("$1"); shift ;;
    esac
  done

  if [[ -n "$DRY_RUN" ]]; then
    RCLONE_DRY="--dry-run"
  fi

  set -- "${positional[@]}"
  local command=${1:-help}
  shift

  case "$command" in
  d | day | c | coffee)     day "$@" ;;
  n | night | a | alcohol)  night "$@" ;;
  rp)                       rclone_pull_all "$@" ;;
  rP)                       rclone_push_all "$@" ;;
  rPf)                      rclone_push_all_force "$@" ;;
  gp)                       git_pull_all "$@" ;;
  gP)                       git_push_all "$@" ;;
  re)                       night_reboot "$@" ;;
  bak)                      system_bak "$@" ;;
  config)                   show_config ;;
  help | --help | -h)       show_help ;;
  *)
    if [[ -z "$command" ]]; then
      show_help
    else
      log_err "未知命令 '$command'"
      show_help
      exit 1
    fi
    ;;
  esac
}

main "$@"
